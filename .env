PORT=8080
DEBUG=true
GEMINI_API_KEY=<api_key>
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
# ---------------------------------------------------------------------------
# Product enrichment (optional)
# Set ENRICH_PRODUCTS=true and add your Serper.dev key to enable real shopping
# URLs, product thumbnails, and prices via Google Shopping search.
# Get a free key (2,500 searches/month) at https://serper.dev
# ---------------------------------------------------------------------------
ENRICH_PRODUCTS=true
SERPER_DEV_API_KEY=<api_key>
ENRICH_LOCATION=United States
ENRICH_CURRENCY=USD
